<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_liquid_main">

    <LinearLayout
        android:id="@+id/glassPanelSignup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        android:background="@drawable/bg_glass_panel"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="NEW ACCOUNT"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Create Piper OS Identity"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/edtSignupName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_glass_input"
            android:hint="Name"
            android:textColorHint="#80FFFFFF"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:maxLines="1"
            android:inputType="textPersonName"/>

        <EditText
            android:id="@+id/edtSignupEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_input"
            android:hint="Email Address"
            android:textColorHint="#80FFFFFF"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:maxLines="1"
            android:inputType="textEmailAddress"/>

        <EditText
            android:id="@+id/edtSignupPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_input"
            android:hint="Password (Min 6 chars)"
            android:textColorHint="#80FFFFFF"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:maxLines="1"
            android:inputType="textPassword"/>

        <EditText
            android:id="@+id/edtSignupConfirm"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_glass_input"
            android:hint="Confirm Password"
            android:textColorHint="#80FFFFFF"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:maxLines="1"
            android:inputType="textPassword"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_glass_panel"
            android:text="SIGNUP"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            app:backgroundTint="#4D00E5FF"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/glassPanelSignup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an ID? "
            android:textColor="#B3FFFFFF"/>

        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login here"
            android:textColor="#00E5FF"
            android:textStyle="bold"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>